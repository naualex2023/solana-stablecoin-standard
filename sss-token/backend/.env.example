# ============================================
# SSS Token Backend Services Configuration
# ============================================
# Copy this file to .env and update values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=sss
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=sss_token
POSTGRES_PORT=5432

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ============================================
# Solana Configuration
# ============================================
# Mainnet, Devnet, or Localnet RPC URL
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# SSS Token Program ID
SSS_PROGRAM_ID=Hf1s4EvjS79S6kcHdKhaZHVQsnsjqMbJgBEFZfaGDPmw

# ============================================
# Service Ports
# ============================================
MINT_BURN_PORT=3001
COMPLIANCE_PORT=3002
WEBHOOK_PORT=3003
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# Keypair Paths (for signing transactions)
# ============================================
# Path to minter keypair JSON file
KEYPAIR_PATH=./secrets/minter.json
# Path to blacklister keypair JSON file
BLACKLISTER_KEYPAIR_PATH=./secrets/blacklister.json

# ============================================
# OFAC Sanctions Configuration
# ============================================
OFAC_API_URL=https://sanctionslist.ofac.treas.gov/api
# Sync interval in milliseconds (default: 24 hours)
OFAC_SYNC_INTERVAL=86400000

# ============================================
# Webhook Configuration
# ============================================
# Timeout for webhook deliveries (ms)
WEBHOOK_TIMEOUT=30000
# Maximum retry attempts
WEBHOOK_MAX_RETRIES=5
# Base delay between retries (ms), exponential backoff
WEBHOOK_RETRY_BASE_DELAY=1000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Production TLS (optional)
# ============================================
# SSL_CERT_PATH=./infrastructure/nginx/ssl/cert.pem
# SSL_KEY_PATH=./infrastructure/nginx/ssl/key.pem
</task_progress>
</write_to_file>