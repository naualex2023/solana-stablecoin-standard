# Solana RPC URL (use your own for production)
# Solana RPC URL
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Fetch mode: 'rpc' (direct) or 'indexer' (backend API)
NEXT_PUBLIC_FETCH_MODE=rpc

# Indexer URL (only needed if NEXT_PUBLIC_FETCH_MODE=indexer)
# NEXT_PUBLIC_INDEXER_URL=https://api.sss-token.com

# For mainnet, use:
# NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Or use a dedicated RPC provider:
# NEXT_PUBLIC_RPC_URL=https://your-helius-or-quicknode-endpoint.com